{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sankarshanmukhopadhyay.github.io/agent-registry-protocol/schemas/decision-receipt.schema.json",
  "title": "ARPA Decision Receipt",
  "description": "Tamper-evident record of an authority evaluation outcome. Required for accountable-or-higher profiles (\u00a718.6, \u00a725.1). Spec \u00a718.6.",
  "x-spec-section": "18.6",
  "allOf": [
    {
      "$ref": "common/envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "record_type": {
          "const": "decision_receipt"
        },
        "request_digest": {
          "type": "string"
        },
        "decision": {
          "type": "string",
          "enum": [
            "allow",
            "allow_with_conditions",
            "deny",
            "indeterminate",
            "not_applicable"
          ]
        },
        "evaluated_authority_records": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "evaluated_status_records": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evaluated_policy_version": {
          "type": "string"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evaluation_time": {
          "type": "string",
          "format": "date-time"
        },
        "validity_duration_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "evaluator_identity": {
          "type": "string"
        },
        "freshness_metadata": {
          "type": "object",
          "properties": {
            "max_status_age_seconds": {
              "type": "integer",
              "minimum": 0
            },
            "observed_at": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "request_digest",
        "decision",
        "evaluated_authority_records",
        "evaluation_time",
        "evaluator_identity",
        "reason_codes"
      ],
      "if": {
        "properties": {
          "decision": {
            "const": "allow_with_conditions"
          }
        }
      },
      "then": {
        "properties": {
          "conditions": {
            "type": "array",
            "minItems": 1
          }
        },
        "required": [
          "conditions"
        ]
      }
    }
  ]
}
